{
  "rewrites": [
    { "source": "/recomend", "destination": "/recomend.html" },
    { "source": "/musica", "destination": "/musica.html" },
    { "source": "/registrarse", "destination": "/registrarse.html" },
    { "source": "/ingresar", "destination": "/ingresar.html" },
    { "source": "/opiniones", "destination": "/opiniones.html" },
    { "source": "/contacto", "destination": "/contacto.html" },
    { "source": "/preguntas-frecuentes", "destination": "/preg_frec.html" },
    { "source": "/acerca-de", "destination": "/acerca_de.html" },
    { "source": "/productos", "destination": "/productos.html" },
    { "source": "/productos/altas", "destination": "/altas.html" },
    { "source": "/productos/listado", "destination": "/listado.html" },
    { "source": "/productos/modificar", "destination": "/modificaciones.html" },
    { "source": "/productos/eliminar", "destination": "/listadoEliminar.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
